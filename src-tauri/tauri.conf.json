{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peti",
  "version": "0.1.0",
  "identifier": "com.arnavpuri.peti",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "© 2026 Arnav Puri",
    "shortDescription": "A calm desktop home for many small projects",
    "longDescription": "Peti gives each project its own self-contained window — its repos run as free-floating Claude Code terminals over a background you recognise, with a task note and a prompt bar. Drives your own `claude` CLI; no API keys.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
